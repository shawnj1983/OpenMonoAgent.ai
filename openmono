#!/usr/bin/env bash
set -eo pipefail

# ──────────────────────────────────────────────────────────────────────────────
# openmono — OpenMono.ai CLI
# Usage: openmono <command>
# ──────────────────────────────────────────────────────────────────────────────

# Resolve to real script location, handling symlinks
# Try $0 first (most reliable), fall back to BASH_SOURCE
OPENMONO_SCRIPT="${0}"
if [[ ! -f "$OPENMONO_SCRIPT" ]]; then
    OPENMONO_SCRIPT="${BASH_SOURCE[0]}"
fi
# Make it absolute if relative
if [[ "$OPENMONO_SCRIPT" != /* ]]; then
    OPENMONO_SCRIPT="$(cd "$(dirname "$OPENMONO_SCRIPT")" && pwd)/$(basename "$OPENMONO_SCRIPT")"
fi
# Follow symlinks to real location
while [[ -L "$OPENMONO_SCRIPT" ]]; do
    OPENMONO_SCRIPT="$(readlink -f "$OPENMONO_SCRIPT" 2>/dev/null || readlink "$OPENMONO_SCRIPT")"
done
REPO_DIR="$(cd "$(dirname "$OPENMONO_SCRIPT")" && pwd)"
DOCKER_DIR="$REPO_DIR/docker"
LLAMA_PORT="${LLAMA_PORT:-7474}"
OPENMONO_VERSION="$(cat "$REPO_DIR/VERSION" 2>/dev/null | tr -d '[:space:]' || echo "unknown")"

# On macOS Apple Silicon, llama-server runs natively via Homebrew (Metal GPU).
# It is never started/stopped via Docker on this platform.
_OPENMONO_OS=$(uname -s)
_OPENMONO_ARCH=$(uname -m)
NATIVE_INFERENCE=false
[[ "$_OPENMONO_OS" == "Darwin" && "$_OPENMONO_ARCH" == "arm64" ]] && NATIVE_INFERENCE=true

# Source macOS native helpers for macOS Apple Silicon
if [[ "$NATIVE_INFERENCE" == "true" ]]; then
    source "$REPO_DIR/scripts/macos/inference.sh"
    source "$REPO_DIR/scripts/macos/tunnel.sh"
fi

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[38;2;163;255;102m' # Neon Green (replaces primary blue)
BOLD='\033[1m'
NC='\033[0m'

info()  { echo -e "${BLUE}[INFO]${NC} $*"; }
ok()    { echo -e "${GREEN}[OK]${NC} $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $*"; }
err()   { echo -e "${RED}[ERROR]${NC} $*" >&2; }

# ── Docker accessibility check ─────────────────────────────────────────────────

_ensure_docker() {
    if docker info &>/dev/null 2>&1; then
        return 0
    fi

    _OS=$(uname -s)
    warn "Docker daemon is not accessible. Attempting to start..."

    if [ "$_OS" = "Darwin" ]; then
        # Try Docker Desktop first (if installed)
        if [ -d "/Applications/Docker.app" ]; then
            info "Starting Docker Desktop..."
            open /Applications/Docker.app
            info "Waiting for Docker daemon (up to 60s)..."
            for i in $(seq 1 60); do
                if docker info &>/dev/null 2>&1; then
                    ok "Docker is ready"
                    return 0
                fi
                sleep 1
                printf "."
            done
            echo ""
            err "Docker Desktop started but daemon is not accessible. Try: colima status"
        # Fallback to Colima if Docker Desktop is not installed
        elif command -v colima &>/dev/null; then
            info "Starting Colima..."
            if colima start 2>/dev/null; then
                for i in $(seq 1 15); do
                    docker info &>/dev/null 2>&1 && { ok "Docker is ready"; return 0; }
                    sleep 1
                done
            fi
            err "Colima failed to start. Try: colima status"
        else
            err "Neither Docker Desktop nor Colima is available. Try: openmono setup"
        fi
    else
        info "Starting Docker daemon..."
        if sudo systemctl start docker 2>/dev/null; then
            for i in $(seq 1 15); do
                docker info &>/dev/null 2>&1 && { ok "Docker is ready"; return 0; }
                sleep 1
            done
            err "Docker started but daemon is not accessible"
        else
            err "Failed to start Docker. Try: sudo systemctl start docker"
        fi
    fi

    exit 1
}

# ── docker/.env helpers (server-side service registry) ──────────────────────────

_env_get() {
    local key="$1" env_file="$DOCKER_DIR/.env"
    [[ -f "$env_file" ]] || return 0
    local line
    line="$(grep "^${key}=" "$env_file" 2>/dev/null | head -1 || true)"
    [[ -n "$line" ]] && printf '%s' "${line#*=}"
}

_env_set() {
    local key="$1" val="$2" env_file="$DOCKER_DIR/.env"
    mkdir -p "$(dirname "$env_file")"; touch "$env_file"
    local tmp="$env_file.tmp"
    grep -v "^${key}=" "$env_file" > "$tmp" 2>/dev/null || true
    printf '%s=%s\n' "$key" "$val" >> "$tmp"
    mv "$tmp" "$env_file"
    chmod 0600 "$env_file"
}

# Reuse the existing LLAMA_API_KEY as the gateway's shared bearer; generate one
# if absent. Sets _LLAMA_KEY_GENERATED so callers can restart llama to apply it.
_ensure_llama_key() {
    local key; key="$(_env_get LLAMA_API_KEY)"
    if [[ -z "$key" ]]; then
        key="$(openssl rand -hex 24)"
        _env_set LLAMA_API_KEY "$key"
        _LLAMA_KEY_GENERATED=1
        info "Generated LLAMA_API_KEY (shared gateway bearer)" >&2
    fi
    printf '%s' "$key"
}

_apply_llama_key_restart() {
    [[ "${_LLAMA_KEY_GENERATED:-0}" == "1" ]] || return 0
    info "Restarting llama-server to apply the new API key..."
    if [[ "$NATIVE_INFERENCE" == "true" ]]; then
        command -v native_cmd_restart &>/dev/null && native_cmd_restart || \
            warn "Restart llama-server manually: openmono restart"
    else
        if (cd "$DOCKER_DIR" && docker compose ps --services 2>/dev/null | grep -q '^llama-server$'); then
            (cd "$DOCKER_DIR" && docker compose up -d llama-server) || \
                warn "Restart manually: cd $DOCKER_DIR && docker compose up -d llama-server"
        fi
    fi
}

# Bring up the gateway + whichever web services are installed (used by cmd_start
# and after 'openmono stop', which tears the whole stack down). Caddy is named
# explicitly so llama-server (also in the server profile) isn't touched here.
_start_web_services() {
    [[ "$(_env_get GATEWAY_ENABLED)" == "true" ]] || return 0
    _ensure_docker
    local profiles=(--profile server) names=(caddy)
    [[ "$(_env_get WEB_SEARCH_ENABLED)" == "true" ]] && { profiles+=(--profile search); names+=(searxng); }
    [[ "$(_env_get WEB_SCRAPE_ENABLED)" == "true" ]] && { profiles+=(--profile scraper); names+=(scrapling); }
    info "Starting gateway (${names[*]})..."
    (cd "$DOCKER_DIR" && docker compose "${profiles[@]}" up -d "${names[@]}") || \
        warn "Failed to start gateway services. Check: docker compose ps"
}

# Install/refresh the Caddy gateway baseline — the single front door the frpc
# tunnel routes through, whether or not SearXNG/Scrapling are added.
_setup_gateway() {
    _ensure_docker
    info "Setting up the Caddy gateway..."
    _ensure_llama_key >/dev/null
    [[ "$NATIVE_INFERENCE" == "true" ]] && _env_set LLAMA_UPSTREAM "host.docker.internal:7474"
    _env_set GATEWAY_ENABLED true
    (cd "$DOCKER_DIR" && docker compose --profile server up -d caddy) || {
        err "Failed to start the gateway. Check: docker compose ps"; return 1
    }
    _apply_llama_key_restart
    local gw_port; gw_port="$(_env_get GATEWAY_PORT)"; gw_port="${gw_port:-7480}"
    _retarget_tunnel_to_gateway "$gw_port"
    _sync_agent_web_config "$gw_port"
    ok "Caddy gateway running on port ${gw_port}"
}

# Mirror the server-side registry (WEB_*_ENABLED) into the local agent config so
# a tool whose service isn't installed skips the gateway entirely (no wasted
# request) rather than trying and falling back. Idempotent; safe to re-run.
_sync_agent_web_config() {
    local gw_port="$1"
    cmd_config set web.gateway "http://host.docker.internal:${gw_port}" >/dev/null
    if [[ "$(_env_get WEB_SEARCH_ENABLED)" == "true" ]]; then
        cmd_config set web.search true >/dev/null
    else
        cmd_config set web.search false >/dev/null
    fi
    if [[ "$(_env_get WEB_SCRAPE_ENABLED)" == "true" ]]; then
        cmd_config set web.scrape true >/dev/null
    else
        cmd_config set web.scrape false >/dev/null
    fi
    local key; key="$(_env_get LLAMA_API_KEY)"
    [[ -n "$key" ]] && cmd_config set llm.api_key "$key" >/dev/null
}

# If an frpc tunnel already exists, re-point it at the gateway so the single
# remote port now reaches llama + web services. No-op when no tunnel is set up
# (fresh installs configure the gateway target directly in tunnel setup).
_retarget_tunnel_to_gateway() {
    local gw_port="$1" changed=false cfg brew_etc
    brew_etc="$(brew --prefix 2>/dev/null)/etc/frp/frpc.toml"
    for cfg in "$HOME/.config/frp/frpc.toml" "$brew_etc" "/etc/frp/frpc.toml"; do
        [[ -f "$cfg" ]] || continue
        grep -q '^localPort' "$cfg" || continue
        grep -q "^localPort[[:space:]]*=[[:space:]]*${gw_port}\b" "$cfg" && continue
        sed -i.bak -E "s/^(localPort[[:space:]]*=[[:space:]]*).*/\1${gw_port}/" "$cfg" 2>/dev/null && rm -f "$cfg.bak" || continue
        changed=true
        info "Re-pointed frpc tunnel ($cfg) at the gateway port ${gw_port}"
    done
    [[ "$changed" == "true" ]] || return 0
    if [[ "$NATIVE_INFERENCE" == "true" ]]; then
        brew services restart frpc >/dev/null 2>&1 && info "Restarted frpc" || \
            warn "Restart the tunnel to apply: openmono tunnel restart"
    else
        sudo systemctl restart frpc >/dev/null 2>&1 && info "Restarted frpc" || \
            warn "Restart the tunnel to apply: openmono tunnel restart"
    fi
}

# ── Optional web services (opt-in, run entirely in Docker) ──────────────────────

cmd_setup_search() {
    _ensure_docker
    info "Installing SearXNG (private web search)..."
    local key; key="$(_ensure_llama_key)"
    [[ -z "$(_env_get SEARXNG_SECRET)" ]] && _env_set SEARXNG_SECRET "$(openssl rand -hex 32)"
    [[ "$NATIVE_INFERENCE" == "true" ]] && _env_set LLAMA_UPSTREAM "host.docker.internal:7474"
    _env_set WEB_SEARCH_ENABLED true

    info "Starting SearXNG + gateway..."
    (cd "$DOCKER_DIR" && docker compose --profile search up -d searxng caddy) || {
        err "Failed to start SearXNG. Check: docker compose ps"; return 1
    }
    _apply_llama_key_restart

    # Point a local (full-mode) agent at the gateway; reuse the shared key.
    local gw_port; gw_port="$(_env_get GATEWAY_PORT)"; gw_port="${gw_port:-7480}"
    _retarget_tunnel_to_gateway "$gw_port"
    _sync_agent_web_config "$gw_port"

    ok "SearXNG installed — WebSearch now routes through the gateway"
}

cmd_setup_scraper() {
    _ensure_docker
    info "Installing Scrapling (web scraper). First build downloads a browser — this can take a few minutes."
    local key; key="$(_ensure_llama_key)"
    [[ "$NATIVE_INFERENCE" == "true" ]] && _env_set LLAMA_UPSTREAM "host.docker.internal:7474"
    _env_set WEB_SCRAPE_ENABLED true

    (cd "$DOCKER_DIR" && docker compose --profile scraper build scrapling) || {
        err "Failed to build the Scrapling image."; return 1
    }
    info "Starting Scrapling + gateway..."
    (cd "$DOCKER_DIR" && docker compose --profile scraper up -d scrapling caddy) || {
        err "Failed to start Scrapling. Check: docker compose ps"; return 1
    }
    _apply_llama_key_restart

    local gw_port; gw_port="$(_env_get GATEWAY_PORT)"; gw_port="${gw_port:-7480}"
    _retarget_tunnel_to_gateway "$gw_port"
    _sync_agent_web_config "$gw_port"

    ok "Scrapling installed — WebFetch now routes through the gateway"
}

# Offered at the end of a fresh full/inference install. Skipped when stdin is
# not a TTY (e.g. piped installers) — the one-liners are printed instead.
prompt_optional_services() {
    # Web services (SearXNG/Scrapling) live on the inference box only. An
    # agent-only box consumes them remotely through the relay, so never offer to
    # install them here — it auto-detects what the inference box exposes.
    case "${OPENMONO_ROLE:-}" in
        full|inference) ;;
        *) return 0 ;;
    esac

    # Inference (server) box: Caddy is the single front door the frpc tunnel
    # routes through, so install it regardless of which web services are added.
    if [[ "${OPENMONO_ROLE:-}" == "inference" ]]; then
        _setup_gateway || warn "Gateway setup hit an issue; retry: openmono setup gateway"
    fi

    echo ""
    echo -e "${BLUE}── Optional web services (private, run in Docker) ───────────${NC}"
    if [[ ! -t 0 ]]; then
        echo "  Add them any time with:"
        echo -e "    ${BOLD}openmono setup search${NC}    # private web search (SearXNG)"
        echo -e "    ${BOLD}openmono setup scraper${NC}   # anti-bot web scraping (Scrapling)"
        return 0
    fi
    # Guard each install so a hiccup in one doesn't abort the rest under 'set -e'.
    local ans
    printf "  Install private web search (SearXNG)? [y/N] "; read -r ans || true
    [[ "$ans" =~ ^[Yy] ]] && { cmd_setup_search || warn "SearXNG setup failed; retry: openmono setup search"; }
    printf "  Install web scraper (Scrapling, downloads a browser)? [y/N] "; read -r ans || true
    [[ "$ans" =~ ^[Yy] ]] && { cmd_setup_scraper || warn "Scrapling setup failed; retry: openmono setup scraper"; }
    echo ""
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_version() {
    echo "openmono $OPENMONO_VERSION"
}

