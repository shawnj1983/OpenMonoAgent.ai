# OpenMono.ai environment variables.
# docker-compose picks these up automatically from docker/.env.
# Copy this file to .env and fill in values for dual-box mode.
# Leave everything empty for local-only (single-machine) mode.

# Model filename inside the models/ directory (auto-set by openmono setup).
# Only set manually if you placed a custom model file in models/.
MODEL_NAME=
MODEL_ALIAS=

# Bearer token enforced by llama-server (--api-key flag).
# Must match the agent's llm.api_key setting.
# Empty = authentication disabled (local-only mode).
LLAMA_API_KEY=

# Rendezvous VM's public hostname or IP.
# Used by scripts/setup-tunnel-*.sh. Not read by docker-compose directly.
FRP_VM_ADDRESS=

# frp server auth token (controls who can establish a tunnel).
# Must match on both the VM's frps.toml and the inference box's frpc.toml.
FRP_AUTH_TOKEN=

# ── Inference-side web services (optional) ───────────────────────────────────
# Managed by 'openmono setup search' / 'openmono setup scraper'. Leave empty if
# you don't run the web stack.

# Host port the Caddy gateway publishes (frpc tunnels this in dual-box mode).
GATEWAY_PORT=47480

# Where Caddy proxies the LLM API. Docker llama: llama-server:7474.
# Native macOS llama (runs on the host): host.docker.internal:7474.
LLAMA_UPSTREAM=llama-server:7474

# Caddy gateway baseline. Set true on the inference box so the single tunnel
# port routes through Caddy (which fronts llama + any web services).
GATEWAY_ENABLED=false

# Which optional services are installed (reported on the gateway's /services).
WEB_SEARCH_ENABLED=false
WEB_SCRAPE_ENABLED=false

# SearXNG instance secret (auto-generated by 'openmono setup search').
SEARXNG_SECRET=

# Agent-side: base URL of the gateway + which services to route through it.
# In dual-box mode set these on the AGENT box to the relay endpoint, e.g.
#   OPENMONO_WEB_GATEWAY=http://relay.openmonoagent.ai:17474
OPENMONO_WEB_GATEWAY=
OPENMONO_WEB_SEARCH=
OPENMONO_WEB_SCRAPE=
